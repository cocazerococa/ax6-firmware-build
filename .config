# 红米 AX6 原厂分区(stock) + NSS满血 编译配置
# 设备：redmi,ax6-stock（无需扩容）
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_redmi_ax6-stock=y

# ── 科学上网 ────────────────────────────────────────────────────
# PassWall
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y

# HomeProxy
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_homeproxy=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ip-full=y

# OpenClash
CONFIG_PACKAGE_luci-app-openclash=y

# ── DNS ────────────────────────────────────────────────────────
# SmartDNS
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_smartdns=y

# mosdns
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_v2dat=y

# AdGuard Home
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_adguardhome=y

# ── 网络工具 ───────────────────────────────────────────────────
# 动态 DNS
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-aliyun=y

# 网络唤醒
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_etherwake=y

# frp 客户端
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_frpc=y

# Lucky
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_lucky=y

# ── 软件商店 ───────────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-lib-fs=y

# ── LuCI 基础 ─────────────────────────────────────────────────
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-sqm=y

# ── 中文语言包 ────────────────────────────────────────────────
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ── PPPoE 拨号支持 ────────────────────────────────────────────
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_luci-proto-ppp=y

# ── 基础工具 ──────────────────────────────────────────────────
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y

# ── IPv6 ──────────────────────────────────────────────────────
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# ── WireGuard ─────────────────────────────────────────────────
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# ── 关闭不需要的包 ────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-nlbwmon=n
CONFIG_PACKAGE_luci-app-statistics=n
